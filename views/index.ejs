<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tech Watch — Daily Tech and AI News</title>
    <meta
      name="description"
      content="Curated news from trusted sources across technology and artificial intelligence. Updated every 6 hours."
    />
    <link rel="icon" type="image/svg+xml" href="/public/favicon.svg" />
    <link rel="stylesheet" href="/public/style.css" />
  </head>
  <body>
    <% const categoryIcons = { Tech: '💻', AI: '🧠' }; %>
    <% const filterChips = [
      { value: 'all', label: 'All' },
      { value: 'tech', label: '💻 Tech' },
      { value: 'ai', label: '🧠 AI' }
    ]; %>
    <div class="page-shell">
      <header class="hero">
        <div>
          <p class="eyebrow">Daily Watchboard</p>
          <h1>tech-watch</h1>
          <p class="hero-copy">
            Curated news from <%= totalSources %> trusted sources across technology and artificial intelligence.
          </p>
          <div class="hero-actions">
            <button type="button" class="refresh-button" id="refreshButton">
              <span class="refresh-spinner" aria-hidden="true"></span>
              <span class="refresh-button-label">Refresh</span>
            </button>
            <span class="hero-status-note">Auto-refreshes every <%= refreshIntervalHours %> hours.</span>
          </div>
        </div>
        <div class="hero-meta hero-meta-compact">
          <span class="pill"><%= totalSources %> sources</span>
          <span class="pill"><%= totalItems %> cached items</span>
        </div>
      </header>

      <% if (!hasData) { %>
        <section class="empty-state">
          <h2>Feed cache is warming up</h2>
          <p>The server is fetching sources now. Reload in a moment.</p>
        </section>
      <% } %>

      <section class="filter-bar" aria-label="Article category filter">
        <div>
          <p class="filter-label">Filter articles</p>
          <p class="filter-copy">All articles are mixed into one feed and sorted newest first.</p>
        </div>
        <div class="filter-chips" role="tablist" aria-label="Category filters">
          <% filterChips.forEach((chip) => { %>
            <button
              type="button"
              class="filter-chip <%= chip.value === 'all' ? 'is-active' : '' %>"
              data-filter="<%= chip.value %>"
              aria-pressed="<%= chip.value === 'all' ? 'true' : 'false' %>"
            >
              <%= chip.label %>
            </button>
          <% }) %>
        </div>
      </section>

      <main class="article-feed" id="articleFeed">
        <% if (articles.length === 0) { %>
          <section class="empty-state">
            <h2>No articles available</h2>
            <p>The cache is warm, but no items matched the current refresh cycle.</p>
          </section>
        <% } else { %>
          <% articles.forEach((item) => { %>
            <article class="article-card" data-category="<%= item.category.toLowerCase() %>">
              <% if (item.image) { %>
                <div class="article-media">
                  <img src="<%= item.image %>" alt="" loading="lazy" />
                </div>
              <% } else { %>
                <div class="article-media article-media-placeholder" aria-hidden="true">
                  <span class="category-icon article-placeholder-icon"><%= categoryIcons[item.category] || '📰' %></span>
                </div>
              <% } %>
              <div class="article-meta">
                <span class="article-category-badge">
                  <span aria-hidden="true"><%= categoryIcons[item.category] || '📰' %></span>
                  <%= item.category %>
                </span>
                <span><%= relativeTime(item.publishedAt) %></span>
              </div>
              <h3>
                <a href="<%= item.link %>" target="_blank" rel="noreferrer">
                  <%= item.title %>
                </a>
              </h3>
              <% if (item.summary) { %>
                <p><%= item.summary %></p>
              <% } %>
              <div class="article-footer">
                <span class="article-source"><span class="source-icon" aria-hidden="true">🌐</span><%= item.source %></span>
                <button
                  type="button"
                  class="club-ia-button"
                  data-title="<%= item.title %>"
                  data-summary="<%= item.summary || '' %>"
                  data-url="<%= item.link %>"
                >
                  Club IA
                </button>
                <time datetime="<%= item.publishedAtIso %>"><%= formatArticleDate(item.publishedAt) %> UTC</time>
              </div>
            </article>
          <% }) %>
        <% } %>
      </main>

      <section class="status-panel">
        <div class="status-header">
          <h2>Source health</h2>
          <p>Partial failures do not stop the page from rendering.</p>
        </div>
        <div class="status-table">
          <% feedStatuses.forEach((feed) => { %>
            <div class="status-row <%= feed.ok ? 'status-ok' : 'status-error' %>">
              <div>
                <strong><%= feed.source %></strong>
                <span><%= feed.category %></span>
              </div>
              <div>
                <% if (feed.ok) { %>
                  <strong><%= feed.itemCount %> items</strong>
                <% } else { %>
                  <strong>Failed</strong>
                <% } %>
                <span><%= feed.durationMs %> ms</span>
              </div>
              <div class="status-note">
                <%= feed.ok ? 'Healthy' : feed.error %>
              </div>
            </div>
          <% }) %>
        </div>
      </section>

      <footer class="footer-status-panel">
        <div class="status-header">
          <h2>Feed status</h2>
          <p>Snapshot of the cache state after the most recent refresh cycle.</p>
        </div>
        <div class="footer-status-grid">
          <div class="stat-card">
            <span class="stat-label">Last updated</span>
            <strong><%= lastUpdated %> UTC</strong>
          </div>
          <div class="stat-card">
            <span class="stat-label">Items cached</span>
            <strong><%= totalItems %></strong>
          </div>
          <div class="stat-card">
            <span class="stat-label">Last refresh attempt</span>
            <strong><%= lastAttemptedAt %> UTC</strong>
          </div>
        </div>
      </footer>
    </div>

    <div class="club-ia-modal" id="clubIaModal" role="dialog" aria-modal="true" aria-labelledby="clubIaModalTitle" hidden>
      <div class="club-ia-dialog">
        <div class="club-ia-dialog-header">
          <div>
            <p class="club-ia-kicker">Club IA</p>
            <h2 id="clubIaModalTitle">Message prêt à partager</h2>
          </div>
          <button type="button" class="club-ia-close" data-club-ia-close aria-label="Fermer">×</button>
        </div>
        <div class="club-ia-body">
          <textarea id="clubIaMessage" class="club-ia-textarea" readonly></textarea>
          <div class="club-ia-meta-row">
            <span id="clubIaStatus" class="club-ia-status">Génération en cours…</span>
            <span id="clubIaCounter" class="club-ia-counter">0 / 400</span>
          </div>
        </div>
        <div class="club-ia-actions">
          <button type="button" class="club-ia-secondary" id="clubIaRegenerate">Regénérer</button>
          <button type="button" class="club-ia-primary" id="clubIaCopy">Copier</button>
        </div>
      </div>
    </div>

    <script>
      (() => {
        const filterChips = Array.from(document.querySelectorAll('.filter-chip'));
        const cards = document.querySelectorAll('.article-card');
        const refreshButton = document.getElementById('refreshButton');
        const clubIaButtons = Array.from(document.querySelectorAll('.club-ia-button'));
        const clubIaModal = document.getElementById('clubIaModal');
        const clubIaMessage = document.getElementById('clubIaMessage');
        const clubIaStatus = document.getElementById('clubIaStatus');
        const clubIaCounter = document.getElementById('clubIaCounter');
        const clubIaCopy = document.getElementById('clubIaCopy');
        const clubIaRegenerate = document.getElementById('clubIaRegenerate');
        const clubIaCloseButtons = Array.from(document.querySelectorAll('[data-club-ia-close]'));
        let activeFilter = 'all';
        let activeClubIaArticle = null;
        let lastFocusedElement = null;

        const applyFilter = () => {
          cards.forEach((card) => {
            const matches = activeFilter === 'all' || card.dataset.category === activeFilter;
            card.hidden = !matches;
          });

          filterChips.forEach((chip) => {
            const isActive = chip.dataset.filter === activeFilter;
            chip.classList.toggle('is-active', isActive);
            chip.setAttribute('aria-pressed', String(isActive));
          });
        };

        if (filterChips.length && cards.length) {
          filterChips.forEach((chip) => {
            chip.addEventListener('click', () => {
              activeFilter = chip.dataset.filter || 'all';
              applyFilter();
            });
          });

          applyFilter();
        }

        if (refreshButton) {
          refreshButton.addEventListener('click', async () => {
            if (refreshButton.disabled) return;

            refreshButton.disabled = true;
            refreshButton.classList.add('is-loading');

            try {
              const response = await fetch('/api/refresh');

              if (!response.ok) {
                throw new Error('Refresh failed');
              }

              await response.json();
              window.location.reload();
            } catch (error) {
              refreshButton.classList.remove('is-loading');
              refreshButton.disabled = false;
              window.alert('Refresh failed. Please try again.');
            }
          });
        }

        const updateClubIaCounter = () => {
          if (!clubIaMessage || !clubIaCounter) return;
          clubIaCounter.textContent = `${clubIaMessage.value.length} / 400`;
          clubIaCounter.classList.toggle('is-over', clubIaMessage.value.length > 400);
        };

        const setClubIaLoading = (isLoading) => {
          if (clubIaRegenerate) {
            clubIaRegenerate.disabled = isLoading;
          }

          if (clubIaCopy) {
            clubIaCopy.disabled = isLoading || !clubIaMessage?.value;
          }

          if (clubIaStatus) {
            clubIaStatus.classList.remove('is-error');
            clubIaStatus.textContent = isLoading ? 'Génération en cours…' : 'Prêt.';
          }
        };

        const openClubIaModal = () => {
          if (!clubIaModal) return;

          lastFocusedElement = document.activeElement;
          clubIaModal.hidden = false;
          document.body.classList.add('club-ia-modal-open');
          clubIaMessage?.focus();
        };

        const closeClubIaModal = () => {
          if (!clubIaModal) return;

          clubIaModal.hidden = true;
          document.body.classList.remove('club-ia-modal-open');

          if (lastFocusedElement && typeof lastFocusedElement.focus === 'function') {
            lastFocusedElement.focus();
          }
        };

        const copyClubIaMessage = async () => {
          if (!clubIaMessage?.value || !clubIaCopy) return;

          try {
            if (navigator.clipboard?.writeText) {
              await navigator.clipboard.writeText(clubIaMessage.value);
            } else {
              clubIaMessage.select();
              document.execCommand('copy');
            }

            const previousLabel = clubIaCopy.textContent;
            clubIaCopy.textContent = 'Copié';
            setTimeout(() => {
              clubIaCopy.textContent = previousLabel;
            }, 1400);
          } catch {
            if (clubIaStatus) {
              clubIaStatus.classList.add('is-error');
              clubIaStatus.textContent = 'Copie impossible.';
            }
          }
        };

        const generateClubIaMessage = async () => {
          if (!activeClubIaArticle || !clubIaMessage) return;

          clubIaMessage.value = '';
          updateClubIaCounter();
          setClubIaLoading(true);

          try {
            const response = await fetch('/api/generate-message', {
              method: 'POST',
              headers: {
                'content-type': 'application/json'
              },
              body: JSON.stringify(activeClubIaArticle)
            });
            const payload = await response.json().catch(() => ({}));

            if (!response.ok) {
              throw new Error(payload.error || 'Génération impossible.');
            }

            clubIaMessage.value = payload.message || '';
            updateClubIaCounter();
            setClubIaLoading(false);
          } catch (error) {
            setClubIaLoading(false);
            if (clubIaStatus) {
              clubIaStatus.classList.add('is-error');
              clubIaStatus.textContent = error.message || 'Génération impossible.';
            }
          }
        };

        clubIaButtons.forEach((button) => {
          button.addEventListener('click', () => {
            activeClubIaArticle = {
              title: button.dataset.title || '',
              summary: button.dataset.summary || '',
              url: button.dataset.url || ''
            };
            openClubIaModal();
            generateClubIaMessage();
          });
        });

        clubIaCloseButtons.forEach((button) => {
          button.addEventListener('click', closeClubIaModal);
        });

        if (clubIaModal) {
          clubIaModal.addEventListener('click', (event) => {
            if (event.target === clubIaModal) {
              closeClubIaModal();
            }
          });
        }

        clubIaCopy?.addEventListener('click', copyClubIaMessage);
        clubIaRegenerate?.addEventListener('click', generateClubIaMessage);

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && clubIaModal && !clubIaModal.hidden) {
            closeClubIaModal();
          }
        });
      })();
    </script>
  </body>
</html>
