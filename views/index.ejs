<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tech Watch — Daily Tech, AI and Geopolitics News</title>
    <meta
      name="description"
      content="Curated news from 12 trusted sources across technology, artificial intelligence, and world geopolitics. Updated every 6 hours."
    />
    <link rel="icon" type="image/svg+xml" href="/public/favicon.svg" />
    <link rel="stylesheet" href="/public/style.css" />
  </head>
  <body>
    <% const categoryIcons = { Tech: '💻', AI: '🧠', Geopolitics: '🌍' }; %>
    <div class="page-shell">
      <header class="hero">
        <div>
          <p class="eyebrow">Daily Watchboard</p>
          <h1>tech-watch</h1>
          <p class="hero-copy">
            Curated news from 12 trusted sources across technology, artificial intelligence,
            and world geopolitics.
          </p>
        </div>
        <div class="hero-meta">
          <div class="stat-card">
            <span class="stat-label">Last updated</span>
            <strong><%= lastUpdated %> UTC</strong>
          </div>
          <div class="stat-card">
            <span class="stat-label">Items cached</span>
            <strong><%= totalItems %></strong>
          </div>
          <div class="stat-card">
            <span class="stat-label">Last refresh attempt</span>
            <strong><%= lastAttemptedAt %> UTC</strong>
          </div>
        </div>
      </header>

      <% if (!hasData) { %>
        <section class="empty-state">
          <h2>Feed cache is warming up</h2>
          <p>The server is fetching sources now. Reload in a moment.</p>
        </section>
      <% } %>

      <section class="filter-bar" aria-label="Article category filter">
        <label class="filter-label" for="categoryFilter">Filter articles</label>
        <select id="categoryFilter" class="filter-select">
          <option value="all">All sources</option>
          <option value="tech">Tech only</option>
          <option value="ai">AI only</option>
          <option value="geopolitics">Geopolitics only</option>
        </select>
      </section>

      <main class="content-grid">
        <% Object.entries(categories).forEach(([category, items]) => { %>
          <section class="category-panel" data-category="<%= category.toLowerCase() %>">
            <div class="category-header">
              <div class="category-title">
                <span class="category-icon" aria-hidden="true"><%= categoryIcons[category] || '📰' %></span>
                <div>
                  <p class="category-kicker">Category</p>
                  <h2><%= category %></h2>
                </div>
              </div>
              <span class="pill"><%= items.length %> items</span>
            </div>

            <% if (items.length === 0) { %>
              <p class="empty-copy">No articles available for this category right now.</p>
            <% } else { %>
              <div class="article-list">
                <% items.forEach((item) => { %>
                  <article class="article-card">
                    <% if (item.image) { %>
                      <div class="article-media">
                        <img src="<%= item.image %>" alt="" loading="lazy" />
                      </div>
                    <% } else { %>
                      <div class="article-media article-media-placeholder" aria-hidden="true">
                        <span class="category-icon article-placeholder-icon"><%= categoryIcons[category] || '📰' %></span>
                      </div>
                    <% } %>
                    <div class="article-meta">
                      <span class="article-source"><span class="source-icon" aria-hidden="true">🌐</span><%= item.source %></span>
                      <span><%= relativeTime(item.publishedAt) %></span>
                    </div>
                    <h3>
                      <a href="<%= item.link %>" target="_blank" rel="noreferrer">
                        <%= item.title %>
                      </a>
                    </h3>
                    <% if (item.summary) { %>
                      <p><%= item.summary %></p>
                    <% } %>
                    <div class="article-footer">
                      <time datetime="<%= item.publishedAtIso %>"><%= formatArticleDate(item.publishedAt) %> UTC</time>
                      <a class="article-link" href="<%= item.link %>" target="_blank" rel="noreferrer">Open article</a>
                    </div>
                  </article>
                <% }) %>
              </div>
            <% } %>
          </section>
        <% }) %>
      </main>

      <section class="status-panel">
        <div class="status-header">
          <h2>Feed status</h2>
          <p>Partial failures do not stop the page from rendering.</p>
        </div>
        <div class="status-table">
          <% feedStatuses.forEach((feed) => { %>
            <div class="status-row <%= feed.ok ? 'status-ok' : 'status-error' %>">
              <div>
                <strong><%= feed.source %></strong>
                <span><%= feed.category %></span>
              </div>
              <div>
                <% if (feed.ok) { %>
                  <strong><%= feed.itemCount %> items</strong>
                <% } else { %>
                  <strong>Failed</strong>
                <% } %>
                <span><%= feed.durationMs %> ms</span>
              </div>
              <div class="status-note">
                <%= feed.ok ? 'Healthy' : feed.error %>
              </div>
            </div>
          <% }) %>
        </div>
      </section>
    </div>
    <script>
      (() => {
        const filter = document.getElementById('categoryFilter');
        const panels = document.querySelectorAll('.category-panel');

        if (!filter || !panels.length) return;

        const applyFilter = () => {
          const selected = filter.value;

          panels.forEach((panel) => {
            const matches = selected === 'all' || panel.dataset.category === selected;
            panel.hidden = !matches;
          });
        };

        filter.addEventListener('change', applyFilter);
        applyFilter();
      })();
    </script>
  </body>
</html>
